# ===========================
# Cresta — Environment Config
# ===========================
# Copy this file to .env and fill in your values

# --- Django ---
SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=False
ALLOWED_HOSTS=cresta.yourdomain.com,localhost,127.0.0.1

# --- Database (PostgreSQL) ---
DATABASE_URL=postgres://cresta:password@db:5432/cresta

# --- Redis (Cache + Celery) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# --- CORS ---
CORS_ALLOWED_ORIGINS=https://cresta.yourdomain.com,http://localhost:5173

# --- Google OAuth ---
VITE_GOOGLE_CLIENT_ID=626273596439-oel2o5r38ap2o7fcll837j8fjplordo8.apps.googleusercontent.com

# --- Frontend API URL (used during build) ---
VITE_API_BASE=http://localhost:8000/api